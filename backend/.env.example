# =============================================================================
# Beauty Master Platform — переменные окружения
# =============================================================================
# ИНСТРУКЦИЯ:
# 1. Скопируй этот файл: cp .env.example .env
# 2. Заполни значения ниже
# 3. Файл .env НЕ коммитится в git (уже в .gitignore)
# =============================================================================

# --- Supabase ------------------------------------------------------------------
# Project URL (уже заполнен — взят из дашборда)
SUPABASE_URL=https://ktmblxavaieujivguemc.supabase.co

# Publishable key (вкладка "Publishable key" → кнопка копировать)
# Начинается с sb_publishable_...
SUPABASE_ANON_KEY=

# Secret key (вкладка "Secret keys" → кнопка копировать)
# Начинается с sb_secret_...
# НИКОМУ НЕ ПОКАЗЫВАЙ ЭТОТ КЛЮЧ
SUPABASE_SERVICE_ROLE_KEY=

# --- JWT -----------------------------------------------------------------------
# Генерируй командой в терминале: openssl rand -hex 64
JWT_SECRET=
JWT_TTL=86400

# --- Шифрование токенов ботов --------------------------------------------------
# Генерируй командой: openssl rand -hex 32
ENCRYPTION_KEY=

# --- Telegram ------------------------------------------------------------------
# Токен бота платформы (бот который онбордит мастеров)
PLATFORM_BOT_TOKEN=

# Твой личный Telegram ID (для admin-панели)
# Узнать: напиши @userinfobot в Telegram
PLATFORM_ADMIN_ID=

# --- YooKassa (заполнить позже, на этапе монетизации) --------------------------
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# --- Тарифы --------------------------------------------------------------------
PLAN_PRO_PRICE_RUB=990
